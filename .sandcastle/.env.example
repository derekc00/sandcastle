# GitHub fine-grained PAT with repo scope
# Create at: https://github.com/settings/tokens?type=beta
# Required permissions: Contents (read/write), Issues (read/write), Pull requests (read/write)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub repo in owner/name format
GITHUB_REPO=owner/repo-name

# Claude Code auth mode: "subscription" or "api-key"
# - subscription: mounts ~/.claude/ from host (Claude Pro/Max login)
# - api-key: uses ANTHROPIC_API_KEY env var
CLAUDE_AUTH=subscription

# Only needed if CLAUDE_AUTH=api-key
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: additional project-specific env vars
# DATABASE_URL=postgresql://...
# OPENAI_API_KEY=sk-...
