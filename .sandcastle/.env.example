# .env is OPTIONAL — only needed for project-specific env vars
#
# GITHUB_TOKEN and GITHUB_REPO are derived automatically from `gh auth token`
# and `gh repo view` on the host. No need to set them here.
#
# Claude Code auth is handled by mounting ~/.claude/ from the host
# (your subscription login). No API key needed.

# Optional: project-specific env vars that your code needs at build/test time
# DATABASE_URL=postgresql://...
# OPENAI_API_KEY=sk-...
# STRIPE_SECRET_KEY=sk_test_...
